# RK3399Pro Edge AI Camera — Linux Kernel Configuration Fragment
#
# 用法: 在 Rockchip BSP 内核 defconfig 基础上合并此片段
#   cd linux-4.19
#   make ARCH=arm64 rk3399pro_linux_defconfig
#   scripts/kconfig/merge_config.sh .config \
#       ../embedded-ai-vision/kernel/config/rk3399pro_edge_fragment.config
#   make ARCH=arm64 CROSS_COMPILE=aarch64-none-linux-gnu- -j$(nproc)
#
# 此片段开启:
#   - NPU (RK1808) 驱动
#   - V4L2 + Media Controller + MIPI CSI
#   - MFC H.264/H.265 硬件编解码
#   - I2C/SPI/UART 外设总线
#   - GPIO + LED + 按键
#   - DMA-BUF/ION/CMA 零拷贝内存
#   - 摄像头传感器驱动 (IMX415)
#   - 自定义 UART 传感器驱动
#   - 自定义 GPIO 触发驱动
#   - PREEMPT 抢占 (降低延迟)
#   - 网络: TCP/IP + Ethernet
#   - 文件系统: ext4 + UBIFS + tmpfs
#   - systemd 所需 cgroups/namespaces
#
# 裁剪掉:
#   - GPU/DRM 图形 (无显示器)
#   - 音频 (无音频设备)
#   - WiFi/BT (用有线)
#   - HDMI (无显示输出)
#   - 摄像头 sensor 驱动 (只保留 IMX415)
#   - 文件系统 (只保留 ext4/UBIFS/tmpfs/proc/sysfs)

# ── NPU (RK1808) ─────────────────────────────────────────
CONFIG_RKNPU=y
CONFIG_RKNPU_MMU=y
CONFIG_ION=y
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=512
CONFIG_DMA_SHARED_BUFFER=y

# ── V4L2 + Media Controller + MIPI CSI ───────────────────
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_CONTROLLER=y
CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_V4L2_SUBDEV_API=y
CONFIG_V4L2_FWNODE=y
CONFIG_V4L2_MEM2MEM_DEV=y
CONFIG_VIDEOBUF2_CORE=y
CONFIG_VIDEOBUF2_DMA_CONTIG=y
CONFIG_VIDEOBUF2_VMALLOC=y
CONFIG_VIDEOBUF2_DMA_SG=y
CONFIG_VIDEO_ROCKCHIP=y
CONFIG_VIDEO_ROCKCHIP_ISP=y
CONFIG_VIDEO_ROCKCHIP_CIF=y
CONFIG_VIDEO_ROCKCHIP_MIPI_CSI2=y
CONFIG_VIDEO_ROCKCHIP_MIPI_DPHY=y

# ── MFC H.264/H.265 硬件编解码 ────────────────────────────
CONFIG_VIDEO_ROCKCHIP_VCODEC=y
CONFIG_VIDEO_ROCKCHIP_VCODEC_H264=y
CONFIG_VIDEO_ROCKCHIP_VCODEC_H265=y
CONFIG_VIDEO_ROCKCHIP_VCODEC_VP8=y

# ── I2C / SPI / UART ─────────────────────────────────────
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_RK3X=y
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_8250_NR_UARTS=6
CONFIG_SERIAL_8250_RUNTIME_UARTS=6
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y

# ── GPIO / LED / 按键 ────────────────────────────────────
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_ROCKCHIP=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y

# ── 摄像头传感器驱动 ─────────────────────────────────────
CONFIG_EDGE_AI_IMX415=m
CONFIG_EDGE_AI_UART_SENSOR=m
CONFIG_EDGE_AI_GPIO_TRIGGER=m
CONFIG_EDGE_AI_SPI_SENSOR=m

# ── 网络 ─────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_STMICRO=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y

# ── 文件系统 ─────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_UBIFS_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y

# ── systemd 所需 ─────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_AUTOFS4_FS=y
CONFIG_FHANDLE=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y

# ── PREEMPT 抢占 (降低视频处理延迟) ──────────────────────
CONFIG_PREEMPT=y
CONFIG_HZ=1000
CONFIG_HIGH_RES_TIMERS=y

# ── 调试 (开发阶段开启, 量产关闭) ─────────────────────────
CONFIG_DEBUG_FS=y
CONFIG_PRINTK=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_EARLY_PRINTK=y
